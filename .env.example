# QuestKids Environment Variables
# Copy this file to .env and customize for your deployment

# ===== Required =====
# Secret key for JWT token signing (change this!)
SECRET_KEY=change-this-to-a-random-secret-string

# ===== Database =====
# SQLite (default, good for single-server):
# DATABASE_URL=sqlite+aiosqlite:///./questkids.db
# PostgreSQL (recommended for multi-user):
DATABASE_URL=postgresql+asyncpg://questkids:${DB_PASSWORD:-questkids}@localhost:5432/questkids
DB_PASSWORD=questkids

# ===== CORS =====
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# ===== JWT Settings =====
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===== Debug =====
DEBUG=false

# ===== File Storage =====
UPLOAD_DIR=./uploads

# ===== Frontend =====
FRONTEND_PORT=80
